  const armLean = pressAmount ? 26 : 0;

  ctx.save();
  ctx.translate(140 + bodyLean, 520);

  ctx.fillStyle = "rgba(0, 0, 0, 0.22)";
  ctx.beginPath();
  ctx.ellipse(24, 224, 128, 28, 0, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "#101720";
  roundedRect(-14, 60, 126, 172, 30);
  ctx.fill();

  ctx.fillStyle = "#f2c49e";
  ctx.beginPath();
  ctx.arc(36, 18, 48, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "#0b0b0e";
  ctx.beginPath();
  ctx.moveTo(-6, 2);
  ctx.quadraticCurveTo(0, -42, 50, -40);
  ctx.quadraticCurveTo(94, -36, 86, 10);
  ctx.quadraticCurveTo(36, 4, -6, 2);
  ctx.fill();

  ctx.strokeStyle = "#44261a";
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.moveTo(60, 20);
  ctx.lineTo(70, 22);
  ctx.stroke();

  ctx.strokeStyle = "#23130b";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(44, 34);
  ctx.lineTo(78, 32);
  ctx.stroke();

  ctx.fillStyle = "#1d2530";
  roundedRect(-20, 110, 58, 86, 24);
  ctx.fill();
  roundedRect(74, 110, 58, 86, 24);
  ctx.fill();

  ctx.save();
  ctx.translate(84, 100);
  ctx.rotate((-12 + armLean) * (Math.PI / 180));
  ctx.fillStyle = "#101720";
  roundedRect(0, 0, 132, 26, 13);
  ctx.fill();
  ctx.fillStyle = "#f2c49e";
  ctx.beginPath();
  ctx.ellipse(134, 12, 18, 12, 0, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();

  ctx.fillStyle = "#101720";
  roundedRect(8, 220, 40, 118, 18);
  ctx.fill();
  roundedRect(64, 220, 40, 118, 18);
  ctx.fill();

  ctx.fillStyle = "#0c1016";
  roundedRect(-8, 326, 58, 22, 12);
  ctx.fill();
  roundedRect(56, 326, 58, 22, 12);
  ctx.fill();

  ctx.fillStyle = "#fff1dc";
  ctx.font = "600 24px Trebuchet MS";
  ctx.textAlign = "left";
  ctx.fillText("Kim Jong Un", -36, 244);
  ctx.fillStyle = "rgba(255, 255, 255, 0.7)";
  ctx.font = "500 18px Trebuchet MS";
  ctx.fillText("supreme sorter", -24, 268);
  ctx.restore();
}

function drawButton() {
  const pressed = state.phase === "alert" || state.phase === "blast";
  const pulse = pressed ? 0.96 : 1 + Math.sin(performance.now() / 300) * 0.02;

  ctx.save();
  ctx.translate(346, 590);

  ctx.fillStyle = "rgba(0, 0, 0, 0.3)";
  ctx.beginPath();
  ctx.ellipse(0, 26, 98, 20, 0, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = "#4d4d52";
  roundedRect(-82, -6, 160, 54, 20);
  ctx.fill();

  ctx.scale(pulse, pressed ? 0.92 : 1);
  const glow = ctx.createRadialGradient(0, 2, 0, 0, 2, 70);
  glow.addColorStop(0, pressed ? "rgba(255, 245, 150, 0.6)" : "rgba(255, 119, 103, 0.26)");
  glow.addColorStop(1, "rgba(255, 80, 56, 0)");
  ctx.fillStyle = glow;
  ctx.beginPath();
  ctx.arc(0, 2, 72, 0, Math.PI * 2);
  ctx.fill();

  const buttonGradient = ctx.createLinearGradient(0, -30, 0, 30);
  buttonGradient.addColorStop(0, "#ff8c79");
  buttonGradient.addColorStop(1, "#b1120e");
  ctx.fillStyle = buttonGradient;
  ctx.beginPath();
  ctx.ellipse(0, 0, 62, 34, 0, 0, Math.PI * 2);
  ctx.fill();

  ctx.strokeStyle = "rgba(255, 255, 255, 0.28)";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.ellipse(0, 0, 62, 34, 0, 0, Math.PI * 2);
  ctx.stroke();

  ctx.fillStyle = "#fff5ea";
  ctx.font = "800 22px Trebuchet MS";
  ctx.textAlign = "center";
  ctx.fillText("NUKE", 0, 8);
  ctx.restore();
}

function drawBars() {
  const layout = barLayout();
  const scale = layout.maxHeight / BAR_MAX;

  for (let i = 0; i < state.bars.length; i += 1) {
    const value = state.bars[i];
    const x = layout.x + i * (layout.barWidth + layout.gap);
    const height = value * scale;
    const y = layout.y - height;
    const status = barStatus(i);

    let fill;
    if (status === "sorted") {
      fill = ["#98efb6", "#35c86b"];
    } else if (status === "scan") {
      fill = ["#fff9c9", "#ffc445"];
    } else if (status === "doomed") {
      fill = ["#ff9d92", "#d31813"];
    } else if (status === "repaired") {
      fill = ["#ffd194", "#ff8b2f"];
    } else {
      fill = ["#f2e8cd", "#8f7d56"];
    }

    const gradient = ctx.createLinearGradient(0, y, 0, layout.y);
    gradient.addColorStop(0, fill[0]);
    gradient.addColorStop(1, fill[1]);

    ctx.fillStyle = "rgba(0, 0, 0, 0.28)";
    ctx.fillRect(x + 8, layout.y, layout.barWidth - 2, 10);

    roundedRect(x, y, layout.barWidth, height, 14);
    ctx.fillStyle = gradient;
    ctx.fill();

    ctx.strokeStyle = "rgba(255, 255, 255, 0.18)";
    ctx.lineWidth = 2;
    ctx.stroke();

    if (status === "scan") {
      ctx.strokeStyle = "rgba(255, 248, 181, 0.8)";
      ctx.lineWidth = 5;
      ctx.stroke();
    }

    ctx.fillStyle = "rgba(32, 12, 6, 0.65)";
    ctx.font = "700 24px Trebuchet MS";
    ctx.textAlign = "center";
    ctx.fillText(String(value), x + layout.barWidth / 2, y + 34);
  }
}

function drawCheckerBeam() {
  if (state.mode === "celebration") {
    return;
  }

  const layout = barLayout();
  const x = layout.x + Math.max(0, state.scanIndex) * (layout.barWidth + layout.gap) + layout.barWidth / 2;
  const beamWidth = Math.max(30, state.bars.length - Math.max(0, state.scanIndex)) * 6;

  ctx.save();
  ctx.globalAlpha = 0.78;
  const beam = ctx.createLinearGradient(0, 170, 0, layout.y);
  beam.addColorStop(0, "rgba(255, 255, 255, 0)");
  beam.addColorStop(0.2, "rgba(255, 235, 170, 0.22)");
  beam.addColorStop(1, "rgba(255, 235, 170, 0)");
  ctx.fillStyle = beam;
  ctx.beginPath();
  ctx.moveTo(x - beamWidth, 170);
  ctx.lineTo(x + beamWidth, 170);
  ctx.lineTo(x + 42, layout.y - 10);
  ctx.lineTo(x - 42, layout.y - 10);
  ctx.closePath();
  ctx.fill();

  ctx.fillStyle = "rgba(255, 240, 186, 0.95)";
  ctx.beginPath();
  ctx.arc(x, 150, 18, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
}

function drawBlast() {
  const range = currentFailureRange();

  if (!range) {
    return;
  }

  const layout = barLayout();
  const startX = layout.x + range.start * (layout.barWidth + layout.gap);
  const endX = layout.x + (range.end + 1) * layout.barWidth + range.end * layout.gap;
  const centerX = (startX + endX) * 0.5;
  const centerY = layout.y - 180;
  const progress = state.phase === "blast" ? state.timer / BLAST_STEP : 0;
  const radius = 60 + progress * 220;

  if (state.phase === "blast") {
    const flash = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, radius);
    flash.addColorStop(0, `rgba(255, 255, 255, ${0.92 * state.blastFlash})`);
    flash.addColorStop(0.3, `rgba(255, 210, 108, ${0.78 * state.blastFlash})`);
    flash.addColorStop(1, "rgba(255, 80, 50, 0)");
    ctx.fillStyle = flash;
    ctx.beginPath();
    ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
    ctx.fill();
  }

  for (const particle of state.particles) {
    ctx.globalAlpha = Math.max(0, particle.life);
    ctx.fillStyle = particle.color;
    ctx.beginPath();
    ctx.arc(particle.x, particle.y, particle.size, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;

  for (const puff of state.smoke) {
    ctx.globalAlpha = Math.max(0, Math.min(1, puff.life / 2)) * puff.alpha;
    ctx.fillStyle = "#4f4f58";
    ctx.beginPath();
    ctx.arc(puff.x, puff.y, puff.radius, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function drawConfetti() {
  for (const piece of state.confetti) {
    ctx.save();
    ctx.translate(piece.x, piece.y);
    ctx.rotate(piece.spin);
    ctx.fillStyle = piece.color;
    ctx.fillRect(-piece.size / 2, -piece.size / 2, piece.size, piece.size * 0.55);
    ctx.restore();
  }
}

function drawLabels() {
  ctx.fillStyle = "#fff0d4";
  ctx.font = "900 48px Impact";
  ctx.textAlign = "left";
  ctx.fillText("North Korea Sort", 64, 96);

  ctx.font = "600 22px Trebuchet MS";
  ctx.fillStyle = "rgba(255, 239, 208, 0.8)";
  ctx.fillText("Right-to-left inspection with catastrophic suffix correction", 66, 130);

  ctx.fillStyle = "rgba(255, 245, 219, 0.92)";
  ctx.font = "700 24px Trebuchet MS";
  ctx.fillText("Bars under inspection", 520, 622);

  const phaseText =
    state.mode === "celebration"
      ? "Celebration"
      : state.phase === "intro"
        ? "Preparing"
        : state.phase === "scan"
          ? "Checking suffix"
          : state.phase === "alert"
            ? "Target locked"
            : state.phase === "blast"
              ? "Nuclear correction"
              : "Rebuilding";

  ctx.fillStyle = "rgba(255, 214, 124, 0.94)";
  ctx.font = "700 28px Trebuchet MS";
  ctx.textAlign = "right";
  ctx.fillText(phaseText, WIDTH - 70, 104);
}

function render() {
  ctx.clearRect(0, 0, WIDTH, HEIGHT);
  drawBackground();
  drawStageFrame();
  drawCheckerBeam();
  drawBars();
  drawBlast();
  drawKim();
  drawButton();
  drawLabels();

  if (state.mode === "celebration") {
    drawConfetti();
  }
}

function renderGameToText() {
  const layout = barLayout();
  const scale = layout.maxHeight / BAR_MAX;
  const payload = {
    coordinate_system: "Origin is top-left of a 1400x900 canvas, x grows right and y grows down.",
    mode: state.mode,
    phase: state.phase,
    scan_index: state.scanIndex,
    failure_range: currentFailureRange(),
    status: state.lastStatus,
    bars: state.bars.map((value, index) => ({
      index,
      value,
      x: Math.round(layout.x + index * (layout.barWidth + layout.gap)),
      y: Math.round(layout.y - value * scale),
      width: Math.round(layout.barWidth),
      height: Math.round(value * scale),
      status: barStatus(index),
    })),
  };

  return JSON.stringify(payload);
}

let lastTimestamp = performance.now();

function animate(timestamp) {
  const dt = Math.min(0.05, (timestamp - lastTimestamp) / 1000);
  lastTimestamp = timestamp;
  update(dt);
  render();
  requestAnimationFrame(animate);
}

window.render_game_to_text = renderGameToText;
window.advanceTime = (ms) => {
  const steps = Math.max(1, Math.round(ms / (1000 / 60)));
  for (let i = 0; i < steps; i += 1) {
    update(1 / 60);
  }
  lastTimestamp = performance.now();
  render();
};

restartBtn.addEventListener("click", initializeSimulation);
resetBtn.addEventListener("click", initializeSimulation);

initializeSimulation();
render();
requestAnimationFrame(animate);

const requestedAdvance = Number(urlParams.get("advance"));
if (Number.isFinite(requestedAdvance) && requestedAdvance > 0) {
  window.setTimeout(() => {
    window.advanceTime(requestedAdvance);
  }, 0);
}
