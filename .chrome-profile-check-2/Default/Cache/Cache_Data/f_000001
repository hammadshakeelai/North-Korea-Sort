const canvas = document.getElementById("sort-canvas");
const ctx = canvas.getContext("2d");
const statusText = document.getElementById("status-text");
const victoryPanel = document.getElementById("victory-panel");
const restartBtn = document.getElementById("restart-btn");
const resetBtn = document.getElementById("reset-btn");

const WIDTH = 1400;
const HEIGHT = 900;
const BAR_COUNT = 14;
const BAR_MIN = 28;
const BAR_MAX = 100;
const SCAN_STEP = 0.65;
const ALERT_STEP = 1.0;
const BLAST_STEP = 1.1;
const REBUILD_STEP = 0.85;
const INTRO_STEP = 0.75;

const state = {
  mode: "running",
  phase: "intro",
  bars: [],
  scanIndex: 0,
  failureStart: null,
  timer: 0,
  particles: [],
  smoke: [],
  confetti: [],
  blastFlash: 0,
  lastStatus: "",
  celebrationPulse: 0,
};

const urlParams = new URLSearchParams(window.location.search);

function randomInt(min, max) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}

function makeBars() {
  const values = [];

  while (values.length < BAR_COUNT) {
    const next = randomInt(BAR_MIN, BAR_MAX);
    if (!values.includes(next)) {
      values.push(next);
    }
  }

  for (let i = values.length - 1; i > 0; i -= 1) {
    const j = randomInt(0, i);
    [values[i], values[j]] = [values[j], values[i]];
  }

  if (values.every((value, index, list) => index === 0 || list[index - 1] <= value)) {
    [values[0], values[values.length - 1]] = [values[values.length - 1], values[0]];
  }

  return values;
}

function barLayout() {
  const x = 510;
  const y = 735;
  const width = 760;
  const gap = 12;
  const barWidth = (width - gap * (BAR_COUNT - 1)) / BAR_COUNT;
  const maxHeight = 420;
  return { x, y, width, gap, barWidth, maxHeight };
}

function initializeSimulation() {
  state.mode = "running";
  state.phase = "intro";
  state.timer = 0;
  state.scanIndex = BAR_COUNT - 2;
  state.failureStart = null;
  state.bars = makeBars();
  state.particles = [];
  state.smoke = [];
  state.confetti = [];
  state.blastFlash = 0;
  state.celebrationPulse = 0;
  victoryPanel.classList.add("hidden");
  setStatus("Kim Jong Un lines up the inspectors for another disastrous sort.");
}

function setStatus(message) {
  if (message !== state.lastStatus) {
    state.lastStatus = message;
    statusText.textContent = message;
  }
}

function currentFailureRange() {
  if (state.failureStart === null) {
    return null;
  }

  return { start: state.failureStart, end: state.bars.length - 1 };
}

function barStatus(index) {
  if (state.mode === "celebration") {
    return "sorted";
  }

  if (state.phase === "alert" || state.phase === "blast" || state.phase === "rebuild") {
    if (index >= state.failureStart) {
      return state.phase === "rebuild" ? "repaired" : "doomed";
    }
  }

  if (state.phase === "scan" || state.phase === "intro") {
    if (index > state.scanIndex) {
      return "sorted";
    }

    if (index === state.scanIndex) {
      return "scan";
    }
  }

  return "idle";
}

function spawnBlastParticles() {
  const range = currentFailureRange();

  if (!range) {
    return;
  }

  const layout = barLayout();
  const startX = layout.x + range.start * (layout.barWidth + layout.gap);
  const endX = layout.x + (range.end + 1) * layout.barWidth + range.end * layout.gap;
  const centerX = (startX + endX) * 0.5;
  const centerY = layout.y - 160;

  for (let i = 0; i < 42; i += 1) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 120 + Math.random() * 260;
    state.particles.push({
      x: centerX,
      y: centerY,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed - 120,
      life: 0.55 + Math.random() * 0.6,
      size: 8 + Math.random() * 22,
      color: i % 3 === 0 ? "#ffe17f" : i % 3 === 1 ? "#ff715f" : "#ffffff",
    });
  }

  for (let i = 0; i < 8; i += 1) {
    state.smoke.push({
      x: centerX + randomInt(-80, 80),
      y: centerY + randomInt(-30, 40),
      vx: randomInt(-30, 30),
      vy: -20 - Math.random() * 40,
      life: 1.4 + Math.random() * 0.9,
      radius: 32 + Math.random() * 26,
      alpha: 0.45 + Math.random() * 0.2,
    });
  }
}

function spawnConfetti() {
  for (let i = 0; i < 5; i += 1) {
    state.confetti.push({
      x: randomInt(480, 1280),
      y: -30 - Math.random() * 120,
      vx: -40 + Math.random() * 80,
      vy: 80 + Math.random() * 120,
      spin: Math.random() * Math.PI,
      spinVelocity: -5 + Math.random() * 10,
      life: 2.4 + Math.random() * 1.3,
      size: 10 + Math.random() * 12,
      color: ["#42d77c", "#ffe17f", "#ff5d55", "#8de8ff"][i % 4],
    });
  }
}

function repairFailureRange() {
  const repaired = state.bars.slice(state.failureStart).sort((left, right) => left - right);
  state.bars.splice(state.failureStart, repaired.length, ...repaired);
}

function completeSort() {
  state.mode = "celebration";
  state.phase = "celebration";
  state.timer = 0;
  state.failureStart = null;
  victoryPanel.classList.remove("hidden");
  setStatus("The bars are fully sorted. The crowd goes wild.");
}

function updateAlgorithm(dt) {
  state.timer += dt;

  if (state.phase === "intro") {
    setStatus("The checker starts from the right side and prepares to judge the suffix.");
    if (state.timer >= INTRO_STEP) {
      state.phase = "scan";
      state.timer = 0;
    }
    return;
  }

  if (state.phase === "scan") {
    setStatus("The suffix inspector is moving left and turning compliant bars green.");

    if (state.timer < SCAN_STEP) {
      return;
    }

    state.timer = 0;

    if (state.bars[state.scanIndex] <= state.bars[state.scanIndex + 1]) {
      state.scanIndex -= 1;
      if (state.scanIndex < 0) {
        completeSort();
      }
      return;
    }

    state.failureStart = state.scanIndex;
    state.phase = "alert";
    setStatus("Disorder detected. The selected bars turn red and the launch button lights up.");
    return;
  }

  if (state.phase === "alert") {
    if (state.timer >= ALERT_STEP) {
      state.phase = "blast";
      state.timer = 0;
      state.blastFlash = 1;
      spawnBlastParticles();
      setStatus("Kim Jong Un slams the red button and nukes the rebellious suffix.");
    }
    return;
  }

  if (state.phase === "blast") {
    state.blastFlash = Math.max(0, 1 - state.timer / BLAST_STEP);
    if (state.timer >= BLAST_STEP) {
      repairFailureRange();
      state.phase = "rebuild";
      state.timer = 0;
      setStatus("The smoke clears and the blasted bars come back in sorted order.");
    }
    return;
  }

  if (state.phase === "rebuild" && state.timer >= REBUILD_STEP) {
    state.failureStart = null;
    state.scanIndex = state.bars.length - 2;
    state.phase = "scan";
    state.timer = 0;
  }
}

function updateParticles(collection, dt, gravity = 0) {
  for (let i = collection.length - 1; i >= 0; i -= 1) {
    const particle = collection[i];
    particle.life -= dt;

    if (particle.life <= 0) {
      collection.splice(i, 1);
      continue;
    }

    particle.x += particle.vx * dt;
    particle.y += particle.vy * dt;
    particle.vy += gravity * dt;
  }
}

function updateSmoke(dt) {
  for (let i = state.smoke.length - 1; i >= 0; i -= 1) {
    const puff = state.smoke[i];
    puff.life -= dt;

    if (puff.life <= 0) {
      state.smoke.splice(i, 1);
      continue;
    }

    puff.x += puff.vx * dt;
    puff.y += puff.vy * dt;
    puff.radius += 14 * dt;
  }
}

function updateConfetti(dt) {
  state.celebrationPulse += dt;
  if (state.celebrationPulse >= 0.14) {
    state.celebrationPulse = 0;
    spawnConfetti();
  }

  for (let i = state.confetti.length - 1; i >= 0; i -= 1) {
    const piece = state.confetti[i];
    piece.life -= dt;

    if (piece.life <= 0 || piece.y > HEIGHT + 80) {
      state.confetti.splice(i, 1);
      continue;
    }

    piece.x += piece.vx * dt;
    piece.y += piece.vy * dt;
    piece.spin += piece.spinVelocity * dt;
    piece.vy += 18 * dt;
  }
}

function update(dt) {
  updateParticles(state.particles, dt, 240);
  updateSmoke(dt);

  if (state.mode === "celebration") {
    updateConfetti(dt);
    return;
  }

  updateAlgorithm(dt);
}

function roundedRect(x, y, width, height, radius) {
  ctx.beginPath();
  ctx.moveTo(x + radius, y);
  ctx.lineTo(x + width - radius, y);
  ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
  ctx.lineTo(x + width, y + height - radius);
  ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
  ctx.lineTo(x + radius, y + height);
  ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
  ctx.lineTo(x, y + radius);
  ctx.quadraticCurveTo(x, y, x + radius, y);
  ctx.closePath();
}

function drawBackground() {
  const sky = ctx.createLinearGradient(0, 0, 0, HEIGHT);
  sky.addColorStop(0, "#5e1211");
  sky.addColorStop(0.5, "#2c0d0d");
  sky.addColorStop(1, "#140707");
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, WIDTH, HEIGHT);

  const glow = ctx.createRadialGradient(980, 140, 40, 980, 140, 360);
  glow.addColorStop(0, "rgba(255, 180, 70, 0.42)");
  glow.addColorStop(1, "rgba(255, 180, 70, 0)");
  ctx.fillStyle = glow;
  ctx.fillRect(0, 0, WIDTH, HEIGHT);

  for (let i = 0; i < 24; i += 1) {
    const x = 540 + i * 32;
    const alpha = i % 3 === 0 ? 0.08 : 0.04;
    ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
    ctx.fillRect(x, 68, 3, 460);
  }

  ctx.fillStyle = "#20110c";
  ctx.fillRect(0, 720, WIDTH, 180);
  ctx.fillStyle = "rgba(0, 0, 0, 0.18)";
  ctx.fillRect(0, 700, WIDTH, 20);
}

function drawStageFrame() {
  ctx.save();
  ctx.fillStyle = "rgba(255, 255, 255, 0.04)";
  roundedRect(34, 32, WIDTH - 68, HEIGHT - 64, 28);
  ctx.fill();
  ctx.strokeStyle = "rgba(255, 196, 104, 0.22)";
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.restore();
}

